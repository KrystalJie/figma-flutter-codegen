#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Visual-validate golden capture artifacts (regenerated per run)
/test/visual_golden_test.dart
/test/visual_golden/

# Geometry-validate rect-dump artifacts (regenerated per run)
/test/visual_rects_test.dart
/test/visual_rects/
/lib/geometry_report.json
/lib/*_keyed.dart

# Raw Figma response dumped next to output for debugging (regenerated per run)
/lib/figma_raw.json
